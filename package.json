{
  "name": "makerspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:dev": "next dev frontend --turbopack",
    "frontend:build": "next build frontend",
    "frontend:start": "next start frontend",
    "backend:dev": "node --watch backend/src/server.js",
    "backend:start": "node backend/src/server.js",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "db:psql": "psql postgresql://makerspace@localhost:5433/makerspace",
    "lint": "next lint frontend"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "embla-carousel-react": "^8.5.2",
    "express": "^4.21.2",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.471.2",
    "next": "^15.1.6",
    "next-auth": "^4.24.11",
    "pg": "^8.14.1",
    "query-string": "^9.1.1",
    "react": "^18.3.1",
    "react-calendar-heatmap": "^1.9.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.173.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-calendar-heatmap": "^1.9.0",
    "@types/react-dom": "^19",
    "@types/three": "^0.173.0",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}